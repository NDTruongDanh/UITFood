{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "REDIS_URL",
    "SENTRY_DSN",
    "SENTRY_ENVIRONMENT",
    "SENTRY_RELEASE",
    "SENTRY_TRACES_SAMPLE_RATE",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "OTEL_SERVICE_NAME",
    "OTEL_EXPORTER_OTLP_ENDPOINT",
    "OTEL_EXPORTER_OTLP_HEADERS",
    "GRAFANA_CLOUD_OTLP_ENDPOINT",
    "GRAFANA_CLOUD_OTLP_USERNAME_OR_INSTANCE_ID",
    "GRAFANA_CLOUD_OTLP_TOKEN",
    "OTEL_RESOURCE_ATTRIBUTES",
    "OTEL_METRICS_EXPORTER",
    "OTEL_LOGS_EXPORTER",
    "OTEL_TRACES_SAMPLER",
    "OTEL_TRACES_SAMPLER_ARG",
    "LOG_LEVEL",
    "VITE_API_BASE_URL",
    "VITE_GRAFANA_FARO_COLLECTOR_URL",
    "VITE_GRAFANA_FARO_APP_NAME",
    "GRAFANA_FARO_SOURCEMAP_ENDPOINT",
    "GRAFANA_FARO_SOURCEMAP_API_KEY",
    "GRAFANA_FARO_APP_ID",
    "GRAFANA_CLOUD_STACK_ID",
    "EXPO_PUBLIC_SENTRY_DSN",
    "EXPO_PUBLIC_SENTRY_ENVIRONMENT",
    "EXPO_PUBLIC_SENTRY_RELEASE",
    "EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE"
  ],
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        ".expo/**",
        "web-build/**"
      ]
    },
    "test": {
      "dependsOn": ["transit"]
    },
    "lint": {
      "dependsOn": ["transit"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["transit"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
