POSTGRES_USER=uitfoodms
POSTGRES_PASSWORD=uitfoodmssecret
POSTGRES_DB=uitfoodms

RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_VHOST=/

# Shared deployment metadata.
NODE_ENV=development
APP_ENV=local
APP_VERSION=local
COMMIT_SHA=local

# Gateway and service route ownership.
PORT=8080
GATEWAY_PROXY_TIMEOUT_MS=30000
GATEWAY_AUTH_TIMEOUT_MS=3000
GATEWAY_CORS_ORIGINS=http://localhost:5173,http://localhost:5174
INTERNAL_AUTH_JWT_SECRET=internal_auth_secret_for_local_dev_only_32_chars
INTERNAL_AUTH_JWT_ISSUER=uitfood-gateway
INTERNAL_AUTH_JWT_TTL_SECONDS=60
INTERNAL_AUTH_TRUSTED_ISSUERS=uitfood-gateway

MEDIA_ROUTES_ENABLED=true
MEDIA_TCP_HOST=localhost
MEDIA_TCP_PORT=4001
MEDIA_MANAGEMENT_PORT=4002
MEDIA_RPC_TIMEOUT_MS=2000

IDENTITY_ROUTES_ENABLED=true
IDENTITY_TCP_HOST=localhost
IDENTITY_TCP_PORT=4011
IDENTITY_MANAGEMENT_PORT=4012
IDENTITY_RPC_TIMEOUT_MS=3000

NOTIFICATION_ROUTES_ENABLED=true
NOTIFICATION_TCP_HOST=localhost
NOTIFICATION_TCP_PORT=4021
NOTIFICATION_MANAGEMENT_PORT=4022
NOTIFICATION_RPC_TIMEOUT_MS=3000
# Notification service only when run outside Compose:
# REDIS_URL=redis://localhost:6380

CATALOG_ROUTES_ENABLED=true
CATALOG_TCP_HOST=localhost
CATALOG_TCP_PORT=4031
CATALOG_MANAGEMENT_PORT=4032
CATALOG_RPC_TIMEOUT_MS=4000

PROMOTION_ROUTES_ENABLED=true
PROMOTION_TCP_HOST=localhost
PROMOTION_TCP_PORT=4041
PROMOTION_MANAGEMENT_PORT=4042
PROMOTION_RPC_TIMEOUT_MS=4000
PROMOTION_RPC_MAX_ATTEMPTS=2
PROMOTION_RPC_REQUIRED=true

PAYMENT_ROUTES_ENABLED=true
PAYMENT_TCP_HOST=localhost
PAYMENT_TCP_PORT=4051
PAYMENT_MANAGEMENT_PORT=4052
PAYMENT_RPC_TIMEOUT_MS=5000
PAYMENT_RPC_MAX_ATTEMPTS=2
PAYMENT_RPC_REQUIRED=true

REVIEW_ROUTES_ENABLED=true
REVIEW_TCP_HOST=localhost
REVIEW_TCP_PORT=4061
REVIEW_MANAGEMENT_PORT=4062
REVIEW_RPC_TIMEOUT_MS=3000

ORDERING_ROUTES_ENABLED=true
ORDERING_TCP_HOST=localhost
ORDERING_TCP_PORT=4071
ORDERING_MANAGEMENT_PORT=4072
ORDERING_RPC_TIMEOUT_MS=6000
IDENTITY_RPC_REQUIRED=false

REPORTING_ROUTES_ENABLED=true
REPORTING_TCP_HOST=localhost
REPORTING_TCP_PORT=4081
REPORTING_MANAGEMENT_PORT=4082
REPORTING_RPC_TIMEOUT_MS=4000

# Cloudinary credentials belong to apps/services/media after cutover.
CLOUDINARY_CLOUD_NAME=STUB_CLOUD
CLOUDINARY_API_KEY=STUB_KEY
CLOUDINARY_API_SECRET=STUB_SECRET

# Backend OpenTelemetry / Grafana Cloud direct OTLP export.
OTEL_SERVICE_NAME=uitfood-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
GRAFANA_CLOUD_OTLP_ENDPOINT=
GRAFANA_CLOUD_OTLP_USERNAME_OR_INSTANCE_ID=
GRAFANA_CLOUD_OTLP_TOKEN=
OTEL_RESOURCE_ATTRIBUTES=
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
LOG_LEVEL=info

# Web Grafana Faro and PostHog.
VITE_API_BASE_URL=http://localhost:8080
VITE_APP_ENV=local
VITE_APP_VERSION=local
VITE_COMMIT_SHA=local
VITE_GRAFANA_FARO_COLLECTOR_URL=
VITE_GRAFANA_FARO_APP_NAME=uitfood-web
GRAFANA_FARO_SOURCEMAP_ENDPOINT=
GRAFANA_FARO_SOURCEMAP_API_KEY=
GRAFANA_FARO_APP_ID=
GRAFANA_CLOUD_STACK_ID=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# Mobile Sentry and PostHog.
# Loopback URLs are rewritten by the mobile app in native development when a
# device-reachable Metro host is available. Use a deployed gateway URL for builds.
EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_APP_ENV=local
EXPO_PUBLIC_APP_VERSION=local
EXPO_PUBLIC_COMMIT_SHA=local
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Payment service VNPay sandbox/payment return settings.
VNPAY_TMN_CODE=STUB_TMN
VNPAY_HASH_SECRET=STUB_SECRET
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8080/api/payments/vnpay/return
MOBILE_PAYMENT_RETURN_URL=uitfood://payment/vnpay-return
PAYMENT_SESSION_TIMEOUT_SECONDS=1800
VNPAY_REFUND_ENABLED=false
VNPAY_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNPAY_REFUND_MAX_RETRIES=5

# Catalog service AI nutrition analysis via direct Ollama Cloud.
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_API_KEY=
HUGGINGFACE_API_KEY=

# Catalog service AI search. The MVP uses deterministic parsing even when provider mode is disabled.
AI_SEARCH_ENABLED=false
AI_SEARCH_MODEL=gpt-oss:20b
AI_SEARCH_TIMEOUT_MS=8000
AI_SEARCH_VERIFICATION_ENABLED=true
AI_SEARCH_VERIFICATION_TIMEOUT_MS=5000
AI_SEARCH_VERIFICATION_BATCH_SIZE=40
AI_SEARCH_MIN_CONFIDENCE=0.65
AI_SEARCH_DAILY_LIMIT_PER_USER=100
AI_SEARCH_RANKING_V2_ENABLED=false
AI_SEARCH_DIVERSITY_ENABLED=true
AI_SEARCH_MAX_ITEMS_PER_RESTAURANT=3
AI_SEARCH_RANKING_WEIGHTS={"retrieval":0.35,"nutrition":0.15,"price":0.10,"distance":0.10,"rating":0.10,"popularity":0.10,"freshness":0.05,"availability":0.05}
AI_SEARCH_EMBEDDING_PROVIDER=ollama
AI_SEARCH_EMBEDDING_BASE_URL=http://localhost:11434
AI_SEARCH_EMBEDDING_MODEL=embeddinggemma
AI_SEARCH_EMBEDDING_VERSION=1
AI_SEARCH_EMBEDDING_DIMENSIONS=768
AI_SEARCH_EMBEDDING_TIMEOUT_MS=8000
AI_SEARCH_EMBEDDING_WORKER_ENABLED=false
AI_SEARCH_EMBEDDING_BATCH_SIZE=20
AI_SEARCH_EMBEDDING_RATE_LIMIT_PER_MINUTE=60
