POSTGRES_USER=food_order
POSTGRES_PASSWORD=foodordersecret
POSTGRES_DB=food_order_db

# Shared deployment metadata.
NODE_ENV=development
APP_ENV=local
APP_VERSION=local
COMMIT_SHA=local

# API OpenTelemetry / Grafana Cloud.
OTEL_SERVICE_NAME=uitfood-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_RESOURCE_ATTRIBUTES=
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
LOG_LEVEL=info

# Optional Grafana Cloud collector override.
GRAFANA_CLOUD_OTLP_ENDPOINT=
GRAFANA_CLOUD_OTLP_USERNAME_OR_INSTANCE_ID=
GRAFANA_CLOUD_OTLP_TOKEN=

# Web Sentry and PostHog.
VITE_API_BASE_URL=http://localhost:3000
VITE_APP_ENV=local
VITE_APP_VERSION=local
VITE_COMMIT_SHA=local
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# Mobile Sentry and PostHog.
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_APP_ENV=local
EXPO_PUBLIC_APP_VERSION=local
EXPO_PUBLIC_COMMIT_SHA=local
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
