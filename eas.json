{
  "cli": {
    "version": ">= 18.13.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN",
        "SENTRY_ORG": "$SENTRY_ORG",
        "SENTRY_PROJECT": "$SENTRY_PROJECT"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "SENTRY_AUTH_TOKEN": "$SENTRY_AUTH_TOKEN",
        "SENTRY_ORG": "$SENTRY_ORG",
        "SENTRY_PROJECT": "$SENTRY_PROJECT"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
