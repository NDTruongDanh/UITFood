{
  "name": "payment",
  "version": "0.0.1",
  "description": "Private Payment service: VNPay attempts, callbacks, timeouts, refunds, and payment result events.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test,scripts}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand --passWithNoTests",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand --forceExit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/microservices": "^11.1.21",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/schedule": "^6.1.3",
    "@uitfood/contracts": "workspace:*",
    "amqp-connection-manager": "^4.1.15",
    "amqplib": "^0.10.9",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.0.11",
    "@nestjs/testing": "^11.1.21",
    "@types/amqplib": "^0.10.8",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "jest": {
    "moduleFileExtensions": ["js", "mjs", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j|mj)s$": ["ts-jest", { "tsconfig": "tsconfig.test.json" }]
    },
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testEnvironment": "node"
  }
}
