DATABASE_URL=postgresql://food_order:foodordersecret@localhost:5432/food_order_db

POSTGRES_USER=food_order
POSTGRES_PASSWORD=foodordersecret
POSTGRES_DB=food_order_db

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Redis — required by OrderingModule (D2-B cart storage + D5-A idempotency)
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# VNPay Payment Gateway
# Obtain credentials from: https://sandbox.vnpayment.vn/devreg/
# ---------------------------------------------------------------------------

# Merchant Terminal Code (e.g. ABCD1234)
VNPAY_TMN_CODE=

# HMAC SHA512 signing key from the VNPay merchant portal — treat as a secret
VNPAY_HASH_SECRET=

# Payment gateway URL
# Sandbox: https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Production: https://pay.vnpay.vn/vpcpay.html
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# Browser redirect after payment (must be whitelisted in VNPay portal)
# NOTE: app.setGlobalPrefix('api') is applied in main.ts — the /api prefix is required.
VNPAY_RETURN_URL=http://localhost:3000/api/payments/vnpay/return

# ---------------------------------------------------------------------------
# VNPay IPN (Instant Payment Notification) callback URL
#
# VNPay's servers call this URL after every payment attempt.
# It MUST be publicly reachable — VNPay cannot reach localhost.
#
# LOCAL DEV SETUP (required to test IPN):
#   1. Install ngrok:  https://ngrok.com/download
#   2. Run:            ngrok http 3000
#   3. Copy the HTTPS forwarding URL (e.g. https://abcd1234.ngrok-free.app)
#   4. Set VNPAY_IPN_URL below:
#        VNPAY_IPN_URL=https://abcd1234.ngrok-free.app/api/payments/vnpay/ipn
#
# STAGING / PROD:
#   VNPAY_IPN_URL=https://api.yourdomain.com/api/payments/vnpay/ipn
#
# If this is unset, VNPay falls back to the static IPN URL in the merchant
# portal. Without a reachable IPN URL, PaymentTransactions will stay at
# 'awaiting_ipn' indefinitely and orders will never be confirmed.
# ---------------------------------------------------------------------------
VNPAY_IPN_URL=

# Payment session timeout in seconds (default: 1800 = 30 minutes)
# PAYMENT_SESSION_TIMEOUT_SECONDS=1800

# ---------------------------------------------------------------------------
# Cloudinary (signed uploads)
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---------------------------------------------------------------------------
# SMTP Email Delivery — optional (Phase N-4)
# When SMTP_HOST is absent, delivery attempts are recorded as
# SMTP_NOT_CONFIGURED failures in notification_delivery_logs (observable).
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@soli.dev

# ---------------------------------------------------------------------------
# Firebase Cloud Messaging (FCM) — optional (Phase N-5)
#
# Path to the Firebase Admin SDK service account JSON key file.
# May be absolute or relative to process.cwd() (the directory from which
# `nest start` is invoked — typically apps/api/ in local dev).
#
# When absent, PUSH_PROVIDER falls back to StubPushProvider which logs
# push delivery attempts without making real FCM calls. Safe for CI/CD.
#
# SECURITY: keep this file out of version control (.gitignore already
# excludes *-FCM-key.json patterns).
#
# To generate: Firebase Console → Project Settings → Service Accounts
#              → Generate New Private Key
# ---------------------------------------------------------------------------
FIREBASE_SERVICE_ACCOUNT_PATH=soli-food-delivery-FCM-key.json