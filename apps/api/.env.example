# Copy this file to apps/api/.env for local API runtime and API E2E tests.
# Keep apps/api/.env out of git.

# ---------------------------------------------------------------------------
# API runtime
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Shared deployment metadata. Set these in every deployed environment.
APP_ENV=local
APP_VERSION=local
COMMIT_SHA=local

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://uitfoodms:uitfoodmssecret@localhost:5432/uitfoodms

# Local E2E tests use a dedicated database. When omitted, test:e2e derives
# postgresql://uitfoodms:uitfoodmssecret@localhost:5432/uitfoodms_test
# from DATABASE_URL and prepares it before Jest starts.
# TEST_DATABASE_URL=postgresql://uitfoodms:uitfoodmssecret@localhost:5432/uitfoodms_test

# Only needed when this app also starts the local Docker Compose database.
POSTGRES_USER=uitfoodms
POSTGRES_PASSWORD=uitfoodmssecret
POSTGRES_DB=uitfoodms

# ---------------------------------------------------------------------------
# Better Auth
# ---------------------------------------------------------------------------
# Must be at least 32 characters in real environments.
BETTER_AUTH_SECRET=replace-with-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
# Cloud deployments (Render, Railway, etc.) provide a single REDIS_URL.
# When set, REDIS_URL takes precedence over REDIS_HOST / REDIS_PORT.
# Use the rediss:// scheme for TLS (required on Render managed Redis).
# REDIS_URL=rediss://<user>:<password>@<host>:<port>

# Local / Docker Compose fallback:
REDIS_HOST=localhost
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# RabbitMQ domain events
# ---------------------------------------------------------------------------
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=uitfood.domain-events
RABBITMQ_PREFETCH=10

# ---------------------------------------------------------------------------
# Internal service RPC/auth controls
# ---------------------------------------------------------------------------
INTERNAL_AUTH_JWT_SECRET=internal_auth_secret_for_local_dev_only_32_chars
INTERNAL_AUTH_JWT_ISSUER=uitfood-api
INTERNAL_AUTH_JWT_TTL_SECONDS=60

# Phase 3 Media service. Keep legacy routes enabled for monolith-only API E2E.
MEDIA_TCP_HOST=localhost
MEDIA_TCP_PORT=4001
MEDIA_RPC_TIMEOUT_MS=2000
MEDIA_RPC_MAX_ATTEMPTS=2
MEDIA_RPC_REQUIRED=false
LEGACY_MEDIA_ROUTES_ENABLED=true

# Phase 4 Identity service. Keep disabled unless running the extracted service.
IDENTITY_RPC_ENABLED=false
IDENTITY_TCP_HOST=localhost
IDENTITY_TCP_PORT=4011
IDENTITY_RPC_TIMEOUT_MS=3000
IDENTITY_RPC_MAX_ATTEMPTS=2
IDENTITY_RPC_REQUIRED=false

# Phase 5 Notification cutover. Keep both true for monolith-only API E2E.
LEGACY_NOTIFICATION_ROUTES_ENABLED=true
LEGACY_NOTIFICATION_RUNTIME_ENABLED=true

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
# Comma-separated list of allowed browser/mobile development origins.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ---------------------------------------------------------------------------
# VNPay payment gateway
# ---------------------------------------------------------------------------
# Sandbox registration: https://sandbox.vnpayment.vn/devreg/
VNPAY_TMN_CODE=STUB_TMN
VNPAY_HASH_SECRET=STUB_SECRET
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/api/payments/vnpay/return
MOBILE_PAYMENT_RETURN_URL=uitfood://payment/vnpay-return

# Must be publicly reachable when testing VNPay IPN locally, for example via ngrok.
VNPAY_IPN_URL=

# Payment session timeout in seconds.
PAYMENT_SESSION_TIMEOUT_SECONDS=1800
VNPAY_REFUND_ENABLED=false
VNPAY_API_URL=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
VNPAY_REFUND_MAX_RETRIES=5

# ---------------------------------------------------------------------------
# Cloudinary signed uploads
# ---------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---------------------------------------------------------------------------
# SMTP email delivery
# ---------------------------------------------------------------------------
# Leave SMTP_HOST empty to use the no-op email provider locally.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@soli.dev

# ---------------------------------------------------------------------------
# Firebase Cloud Messaging
# ---------------------------------------------------------------------------
# Path may be absolute or relative to apps/api.
FIREBASE_SERVICE_ACCOUNT_PATH=

# ---------------------------------------------------------------------------
# AI nutrition extraction via Ollama
# ---------------------------------------------------------------------------
# Direct Ollama Cloud API. Use model names from https://ollama.com/api/tags
# without the local "-cloud" suffix.
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_API_KEY=
AI_SEARCH_ENABLED=false
AI_SEARCH_MODEL=gpt-oss:20b
AI_SEARCH_TIMEOUT_MS=8000
AI_SEARCH_MIN_CONFIDENCE=0.65
AI_SEARCH_DAILY_LIMIT_PER_USER=100
AI_SEARCH_RANKING_V2_ENABLED=false
AI_SEARCH_DIVERSITY_ENABLED=true
AI_SEARCH_MAX_ITEMS_PER_RESTAURANT=3
AI_SEARCH_RANKING_WEIGHTS={"retrieval":0.35,"nutrition":0.15,"price":0.10,"distance":0.10,"rating":0.10,"popularity":0.10,"freshness":0.05,"availability":0.05}

AI_SEARCH_EMBEDDING_BASE_URL=http://localhost:11434
AI_SEARCH_EMBEDDING_MODEL=embeddinggemma
AI_SEARCH_EMBEDDING_VERSION=1
AI_SEARCH_EMBEDDING_DIMENSIONS=768
AI_SEARCH_EMBEDDING_TIMEOUT_MS=8000
AI_SEARCH_EMBEDDING_WORKER_ENABLED=false
AI_SEARCH_EMBEDDING_BATCH_SIZE=20
AI_SEARCH_EMBEDDING_RATE_LIMIT_PER_MINUTE=60

# ---------------------------------------------------------------------------
# OpenTelemetry
# ---------------------------------------------------------------------------
# Use http://localhost:4318 when the API runs on your host machine.
# Use http://otel-collector:4318 when the API runs inside Docker Compose.
OTEL_SERVICE_NAME=uitfood-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_RESOURCE_ATTRIBUTES=
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
LOG_LEVEL=info

# Optional when exporting directly to Grafana Cloud instead of the local collector.
# Example header format: Authorization=Basic%20<base64-instance-id-and-token>
# OTEL_EXPORTER_OTLP_HEADERS=
