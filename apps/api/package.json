{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node --require ./dist/telemetry dist/main",
    "lint": "eslint \"{src,apps,libs}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:architecture": "jest architecture/module-boundaries.spec.ts --runInBand",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "db:test:prepare": "tsx test/setup/prepare-local-e2e-db.ts",
    "test:e2e": "tsx test/setup/prepare-local-e2e-db.ts && node --experimental-vm-modules node_modules/jest/bin/jest.js --config ./test/jest-e2e.json --forceExit --detectOpenHandles",
    "test:e2e:local": "pnpm run test:e2e",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:extensions": "tsx src/drizzle/ensure-extensions.ts",
    "db:migrate": "pnpm run db:extensions && drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "pnpm run db:extensions && drizzle-kit push",
    "db:seed:nutrition:usda": "tsx src/drizzle/seeds/usda-foundation-foods.seed.ts",
    "ai-search:backfill-embeddings": "tsx src/module/restaurant-catalog/search/indexing/ai-search-backfill.ts",
    "ai-search:refresh-ranking-stats": "tsx src/module/restaurant-catalog/search/ai/ai-search-ranking-stats-refresh.ts",
    "db:seed:admin": "tsx src/drizzle/seeds/admin.seed.ts",
    "db:seed:dietary-tags": "tsx src/drizzle/seeds/dietary-tags.seed.ts",
    "db:seed:restaurants": "pnpm run db:seed:dietary-tags && tsx src/drizzle/seeds/vegan-nutrition.seed.ts && tsx src/drizzle/seeds/beverage-restaurants.seed.ts && tsx src/drizzle/seeds/food-and-beverage-restaurants.seed.ts && tsx src/drizzle/seeds/nearby-vnu-nutrition.seed.ts && tsx src/drizzle/seeds/reviews.seed.ts",
    "db:seed:reviews": "tsx src/drizzle/seeds/reviews.seed.ts",
    "db:seed:analytics:fresh-bowl": "tsx src/drizzle/seeds/analytics-orders-fresh-bowl-vnu.seed.ts"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.11",
    "@better-auth/expo": "^1.6.11",
    "@huggingface/inference": "^4.13.19",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.21",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/platform-socket.io": "^11.1.21",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/websockets": "^11.1.21",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.218.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/instrumentation-runtime-node": "^0.31.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-logs": "^0.218.0",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@scalar/nestjs-api-reference": "^1.1.16",
    "@thallesp/nestjs-better-auth": "^2.6.0",
    "@types/ioredis": "^5.0.0",
    "better-auth": "^1.6.11",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.10.0",
    "ioredis": "^5.10.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.21",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.8.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-seed": "^0.3.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "mjs",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j|mj)s$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(@thallesp/nestjs-better-auth|better-auth|@better-auth/drizzle-adapter|@better-auth/expo)/)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/test-setup.ts"
    ],
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
