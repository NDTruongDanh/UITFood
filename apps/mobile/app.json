{
  "expo": {
    "name": "UIT Food",
    "slug": "uit-food",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "uitfood",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.truongdanh.uitfood",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "We use your location to find nearby restaurants and improve delivery accuracy."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0d631b",
        "foregroundImage": "./assets/images/app-icon-foreground.png",
        "monochromeImage": "./assets/images/app-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.truongdanh.uitfood",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app-favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "@sentry/react-native/expo",
        {
          "organization": "nguyen-ai-truong-danh",
          "project": "uitfood-mobile"
        }
      ],
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app-icon-monochrome.png",
          "color": "#0d631b"
        }
      ],
      "@react-native-firebase/app/app.plugin.js",
      "@react-native-firebase/messaging/app.plugin.js",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-logo.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#fcf9f8",
          "dark": {
            "image": "./assets/images/splash-logo.png",
            "backgroundColor": "#fcf9f8"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-secure-store",
      "expo-web-browser",
      "expo-localization"
    ],
    "extra": {
      "geocoding": {
        "baseUrl": "https://photon.komoot.io",
        "timeout": 5000,
        "retry": {
          "maxRetries": 3
        }
      },
      "eas": {
        "projectId": "0fad1c88-699b-4597-af1f-4e30f2d257b6"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true,
      "buildCacheProvider": "eas"
    }
  }
}
