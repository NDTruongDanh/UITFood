# ---------------------------------------------------------------------------
# Mobile runtime
# ---------------------------------------------------------------------------
# Loopback URLs are rewritten in native development to the Metro host when
# possible, or to Android's host-machine gateway for Android emulators.
# Use the deployed gateway URL for production/EAS builds.
EXPO_PUBLIC_API_URL=http://localhost:8080

# Shared deployment metadata. These are attached to Sentry events.
EXPO_PUBLIC_APP_ENV=local
EXPO_PUBLIC_APP_VERSION=local
EXPO_PUBLIC_COMMIT_SHA=local

# ---------------------------------------------------------------------------
# Sentry React Native telemetry
# ---------------------------------------------------------------------------
# Leave EXPO_PUBLIC_SENTRY_DSN empty to disable Sentry locally.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development
EXPO_PUBLIC_SENTRY_RELEASE=local
EXPO_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Sentry source map upload for Expo/EAS builds.
# These are build-time secrets and must not use the EXPO_PUBLIC_ prefix.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

