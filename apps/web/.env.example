# ---------------------------------------------------------------------------
# Web runtime
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:3000

# Shared deployment metadata. These are attached to Grafana Faro and PostHog events.
VITE_APP_ENV=local
VITE_APP_VERSION=local
VITE_COMMIT_SHA=local

# ---------------------------------------------------------------------------
# Grafana Faro observability
# ---------------------------------------------------------------------------
# Leave VITE_GRAFANA_FARO_COLLECTOR_URL empty to disable Faro locally.
VITE_GRAFANA_FARO_COLLECTOR_URL=
VITE_GRAFANA_FARO_APP_NAME=uitfood-web

# Grafana Faro source map upload during `pnpm --filter web build`.
# These are build-time secrets and must not be exposed with the VITE_ prefix.
GRAFANA_FARO_SOURCEMAP_ENDPOINT=
GRAFANA_FARO_SOURCEMAP_API_KEY=
GRAFANA_FARO_APP_ID=
GRAFANA_CLOUD_STACK_ID=

# ---------------------------------------------------------------------------
# PostHog product analytics
# ---------------------------------------------------------------------------
# Leave VITE_POSTHOG_KEY empty to disable analytics locally.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
