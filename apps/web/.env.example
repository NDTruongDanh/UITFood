# ---------------------------------------------------------------------------
# Web runtime
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:3000

# Shared deployment metadata. These are attached to Sentry and PostHog events.
VITE_APP_ENV=local
VITE_APP_VERSION=local
VITE_COMMIT_SHA=local

# ---------------------------------------------------------------------------
# Sentry browser telemetry
# ---------------------------------------------------------------------------
# Leave VITE_SENTRY_DSN empty to disable Sentry locally.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=local
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Sentry source map upload during `pnpm --filter web build`.
# These are build-time secrets and must not be exposed with the VITE_ prefix.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ---------------------------------------------------------------------------
# PostHog product analytics
# ---------------------------------------------------------------------------
# Leave VITE_POSTHOG_KEY empty to disable analytics locally.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
