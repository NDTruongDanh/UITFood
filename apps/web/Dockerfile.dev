FROM node:22-alpine
RUN apk add --no-cache libc6-compat
RUN npm install -g pnpm@11.1.2

WORKDIR /app

# Copy all workspace manifests so pnpm can resolve the full workspace.
# Source code is mounted at runtime via a docker-compose volume.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml turbo.json ./
COPY apps/gateway/package.json ./apps/gateway/package.json
COPY apps/web/package.json ./apps/web/package.json
COPY apps/admin/package.json ./apps/admin/package.json
COPY apps/mobile/package.json ./apps/mobile/package.json
COPY apps/services/catalog/package.json ./apps/services/catalog/package.json
COPY apps/services/identity/package.json ./apps/services/identity/package.json
COPY apps/services/media/package.json ./apps/services/media/package.json
COPY apps/services/notification/package.json ./apps/services/notification/package.json
COPY apps/services/ordering/package.json ./apps/services/ordering/package.json
COPY apps/services/payment/package.json ./apps/services/payment/package.json
COPY apps/services/promotion/package.json ./apps/services/promotion/package.json
COPY apps/services/reporting/package.json ./apps/services/reporting/package.json
COPY apps/services/review/package.json ./apps/services/review/package.json

RUN pnpm install --frozen-lockfile

EXPOSE 5173
CMD ["pnpm", "--filter", "web", "run", "dev"]
