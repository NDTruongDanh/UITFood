# Copy this file to production.auto.tfvars, then replace the placeholder values.
# production.auto.tfvars is ignored by git and is loaded automatically by Terraform
# when you run terraform plan/apply from this directory.

api_image_tag = "sha-replace-me"
web_image_tag = "sha-replace-me"

api_health_check_path = "/api/ready"
web_health_check_path = "/healthz"

api_env_vars = {
  BETTER_AUTH_SECRET = "replace-me"
  BETTER_AUTH_URL    = "https://api.example.com"
  CORS_ORIGIN        = "https://app.example.com"

  REDIS_HOST = "replace-me"
  REDIS_PORT = "6379"

  FIREBASE_SERVICE_ACCOUNT_PATH = "/etc/secrets/firebase-service-account.json"

  CLOUDINARY_CLOUD_NAME = "replace-me"
  CLOUDINARY_API_KEY    = "replace-me"
  CLOUDINARY_API_SECRET = "replace-me"

  SMTP_HOST = "replace-me"
  SMTP_PORT = "587"
  SMTP_USER = "replace-me"
  SMTP_PASS = "replace-me"

  VNPAY_TMN_CODE    = "replace-me"
  VNPAY_HASH_SECRET = "replace-me"
  VNPAY_URL         = "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
  VNPAY_RETURN_URL  = "https://api.example.com/payments/vnpay/return"

  APP_ENV                    = "production"
  APP_VERSION                = "1.0.0"
  COMMIT_SHA                 = "sha-replace-me"
  OTEL_SERVICE_NAME          = "uitfood-api"
  OTEL_EXPORTER_OTLP_ENDPOINT = "https://otlp-gateway-prod-REGION.grafana.net/otlp"
  OTEL_EXPORTER_OTLP_HEADERS = "Authorization=Basic%20<base64-instance-id-and-token>"
  OTEL_RESOURCE_ATTRIBUTES   = "deployment.environment=production"
  OTEL_TRACES_EXPORTER       = "otlp"
  OTEL_METRICS_EXPORTER      = "otlp"
  OTEL_LOGS_EXPORTER         = "otlp"
  OTEL_TRACES_SAMPLER        = "parentbased_traceidratio"
  OTEL_TRACES_SAMPLER_ARG    = "0.1"
  LOG_LEVEL                  = "info"
}

web_env_vars = {
  VITE_API_BASE_URL                 = "https://api.example.com"
  VITE_APP_ENV                      = "production"
  VITE_APP_VERSION                  = "1.0.0"
  VITE_COMMIT_SHA                   = "sha-replace-me"
  VITE_SENTRY_DSN                   = "https://public-key@o000000.ingest.sentry.io/000000"
  VITE_SENTRY_RELEASE               = "sha-replace-me"
  VITE_SENTRY_TRACES_SAMPLE_RATE    = "0.1"
  VITE_POSTHOG_KEY                  = "phc_replace-me"
  VITE_POSTHOG_HOST                 = "https://app.posthog.com"
}
