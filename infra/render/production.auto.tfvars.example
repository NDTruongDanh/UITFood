# Copy this file to production.auto.tfvars, then replace the placeholder values.
# production.auto.tfvars is ignored by git and is loaded automatically by Terraform
# when you run terraform plan/apply from this directory.

api_image_tag     = "sha-replace-me"
web_image_tag     = "sha-replace-me"
gateway_image_tag = "sha-replace-me"
media_image_tag   = "sha-replace-me"

api_health_check_path     = "/api/ready"
web_health_check_path     = "/healthz"
gateway_health_check_path = "/ready"

# Gateway upstream. Leave empty to default to the managed API service URL,
# or pin to an internal/private URL once private networking is configured.
gateway_monolith_upstream_url = ""

# Phase 1 = staging cutover only: keep the public domain on the API until the
# gateway is validated, then move it here.
# gateway_custom_domains = [{ name = "app.example.com" }]

gateway_env_vars = {
  GATEWAY_PROXY_TIMEOUT_MS = "30000"
}

gateway_cors_origins = "https://app.example.com,https://admin.example.com"

# Set both switches atomically during cutover. Rollback reverses them only
# after target-to-source synchronization reports matching hashes.
media_routes_enabled        = false
legacy_media_routes_enabled = true

media_env_vars = {
  CLOUDINARY_CLOUD_NAME = "replace-me"
  CLOUDINARY_API_KEY    = "replace-me"
  CLOUDINARY_API_SECRET = "replace-me"
}

api_env_vars = {
  BETTER_AUTH_SECRET = "replace-me"
  BETTER_AUTH_URL    = "https://api.example.com"
  CORS_ORIGIN        = "https://app.example.com"

  REDIS_HOST = "replace-me"
  REDIS_PORT = "6379"

  FIREBASE_SERVICE_ACCOUNT_PATH = "/etc/secrets/firebase-service-account.json"

  # Retain only through the Media rollback window, then remove from API.
  CLOUDINARY_CLOUD_NAME = "replace-me"
  CLOUDINARY_API_KEY    = "replace-me"
  CLOUDINARY_API_SECRET = "replace-me"

  SMTP_HOST = "replace-me"
  SMTP_PORT = "587"
  SMTP_USER = "replace-me"
  SMTP_PASS = "replace-me"

  VNPAY_TMN_CODE    = "replace-me"
  VNPAY_HASH_SECRET = "replace-me"
  VNPAY_URL         = "https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"
  VNPAY_RETURN_URL  = "https://api.example.com/payments/vnpay/mobile-return"
  MOBILE_PAYMENT_RETURN_URL = "uitfood://payment/vnpay-return"
  PAYMENT_SESSION_TIMEOUT_SECONDS = "1800"

  APP_ENV                    = "production"
  APP_VERSION                = "1.0.0"
  COMMIT_SHA                 = "sha-replace-me"
  OTEL_SERVICE_NAME          = "uitfood-api"
  GRAFANA_CLOUD_OTLP_ENDPOINT = "https://otlp-gateway-prod-REGION.grafana.net/otlp"
  GRAFANA_CLOUD_OTLP_USERNAME_OR_INSTANCE_ID = "replace-me"
  GRAFANA_CLOUD_OTLP_TOKEN    = "replace-me"
  OTEL_RESOURCE_ATTRIBUTES   = "deployment.environment=production"
  OTEL_TRACES_EXPORTER       = "otlp"
  OTEL_METRICS_EXPORTER      = "otlp"
  OTEL_LOGS_EXPORTER         = "otlp"
  OTEL_TRACES_SAMPLER        = "parentbased_traceidratio"
  OTEL_TRACES_SAMPLER_ARG    = "0.1"
  LOG_LEVEL                  = "info"
}

web_env_vars = {
  VITE_API_BASE_URL                 = "https://api.example.com"
  VITE_APP_ENV                      = "production"
  VITE_APP_VERSION                  = "1.0.0"
  VITE_COMMIT_SHA                   = "sha-replace-me"
  VITE_GRAFANA_FARO_COLLECTOR_URL   = "https://faro-collector-prod-REGION.grafana.net/collect/replace-me"
  VITE_GRAFANA_FARO_APP_NAME        = "uitfood-web"
  VITE_POSTHOG_KEY                  = "phc_replace-me"
  VITE_POSTHOG_HOST                 = "https://app.posthog.com"
}
